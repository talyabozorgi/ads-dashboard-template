export default function EyebrowCoursePage() {
  const [form, setForm] = useState({ name: '', phone: '', email: '' });
  const [pricingForm, setPricingForm] = useState({ name: '', phone: '', email: '' });
  const [openFaq, setOpenFaq] = useState<number | null>(null);
  const [submitting, setSubmitting] = useState(false);
  const countdown = useCountdown();
  const utmRef = useRef<string>('');

  useEffect(() => {
    const params = new URLSearchParams(window.location.search);
    const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'fbclid'];
    const utmParts: string[] = [];
    utmKeys.forEach(k => {
      const v = params.get(k);
      if (v) utmParts.push(`${k}=${encodeURIComponent(v)}`);
    });
    utmRef.current = utmParts.join('&');
  }, []);

  useEffect(() => {
    const fired = new Set<string>();
    function track(event: string, params?: Record<string, unknown>) {
      if (fired.has(event)) return;
      fired.add(event);
      if (typeof window !== 'undefined' && window.fbq) {
        window.fbq('trackCustom', event, params);
      }
    }
    function onScroll() {
      const pct = Math.round((window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100);
      if (pct >= 25) track('ScrollDepth25', { page: 'eyebrow_course' });
      if (pct >= 50) track('ScrollDepth50', { page: 'eyebrow_course' });
      if (pct >= 75) track('ScrollDepth75', { page: 'eyebrow_course' });
      if (pct >= 90) track('ScrollDepth90', { page: 'eyebrow_course' });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        if (e.target.id === 'section-pricing') track('ViewedPricing', { page: 'eyebrow_course' });
        if (e.target.id === 'cta-form') track('ViewedCTA', { page: 'eyebrow_course' });
      });
    }, { threshold: 0.3 });
    ['section-pricing', 'cta-form'].forEach(id => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
    return () => {
      window.removeEventListener('scroll', onScroll);
      observer.disconnect();
    };
  }, []);

  function getPurchaseUrl() {
    return utmRef.current ? `${BASE_PURCHASE_URL}?${utmRef.current}` : BASE_PURCHASE_URL;
  }

  function trackLead(email: string) {
    if (typeof window !== 'undefined' && window.fbq) {
      window.fbq('track', 'Lead', { content_name: 'eyebrow_course', currency: 'ILS', value: 197 });
      window.fbq('track', 'InitiateCheckout', { content_name: 'eyebrow_course', currency: 'ILS', value: 197 });
    }
  }

  async function subscribeToRavMeser(data: { name: string; phone: string; email: string }) {
    try {
      const params = new URLSearchParams(window.location.search);
      await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          ...data,
          utm_source: params.get('utm_source') || '',
          utm_medium: params.get('utm_medium') || '',
          utm_campaign: params.get('utm_campaign') || '',
          utm_content: params.get('utm_content') || '',
        }),
      });
    } catch {
      // don't block the user if this fails
    }
  }

  function savePendingPurchase(data: { name: string; phone: string; email: string }) {
    const params = new URLSearchParams(window.location.search);
    localStorage.setItem('pending_buyer', JSON.stringify({
      ...data,
      utm_content: params.get('utm_content') || '',
      utm_campaign: params.get('utm_campaign') || '',
      utm_source: params.get('utm_source') || '',
    }));
  }

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setSubmitting(true);
    trackLead(form.email);
    savePendingPurchase(form);
    window.location.href = getPurchaseUrl();
  };

  const handlePricingSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setSubmitting(true);
    trackLead(pricingForm.email);
    savePendingPurchase(pricingForm);
    window.location.href = getPurchaseUrl();
  };

