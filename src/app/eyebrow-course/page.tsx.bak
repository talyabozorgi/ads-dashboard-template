    <motion.button
      onClick={scrollToForm}
      className="w-full sm:w-auto bg-[#C49A8A] text-white py-4 px-10 rounded-2xl font-bold text-xl shadow-lg hover:bg-[#B5897A] transition-all duration-300"
      whileHover={{ scale: 1.03 }}
      whileTap={{ scale: 0.97 }}
    >
      {text}
    </motion.button>
  );
}

